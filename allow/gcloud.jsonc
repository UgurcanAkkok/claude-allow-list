{
  "permissions": {
    "allow": [
      // ── Auth & config ─────────────────────────────────────────────────────

      "Bash(gcloud auth list:*)",
      "Bash(gcloud config list:*)",
      "Bash(gcloud config get:*)",
      "Bash(gcloud config configurations list:*)",
      "Bash(gcloud config configurations describe:*)",
      "Bash(gcloud info:*)",
      "Bash(gcloud version:*)",

      // ── Projects ──────────────────────────────────────────────────────────

      "Bash(gcloud projects list:*)",
      "Bash(gcloud projects describe:*)",
      "Bash(gcloud projects get-iam-policy:*)",

      // ── Compute (GCE) ─────────────────────────────────────────────────────

      "Bash(gcloud compute instances list:*)",
      "Bash(gcloud compute instances describe:*)",
      "Bash(gcloud compute machine-types list:*)",
      "Bash(gcloud compute disk-types list:*)",
      "Bash(gcloud compute disks list:*)",
      "Bash(gcloud compute disks describe:*)",
      "Bash(gcloud compute images list:*)",
      "Bash(gcloud compute images describe:*)",
      "Bash(gcloud compute snapshots list:*)",
      "Bash(gcloud compute snapshots describe:*)",
      "Bash(gcloud compute networks list:*)",
      "Bash(gcloud compute networks describe:*)",
      "Bash(gcloud compute networks subnets list:*)",
      "Bash(gcloud compute networks subnets describe:*)",
      "Bash(gcloud compute firewall-rules list:*)",
      "Bash(gcloud compute firewall-rules describe:*)",
      "Bash(gcloud compute routers list:*)",
      "Bash(gcloud compute routers describe:*)",
      "Bash(gcloud compute routes list:*)",
      "Bash(gcloud compute addresses list:*)",
      "Bash(gcloud compute addresses describe:*)",
      "Bash(gcloud compute forwarding-rules list:*)",
      "Bash(gcloud compute forwarding-rules describe:*)",
      "Bash(gcloud compute target-pools list:*)",
      "Bash(gcloud compute backend-services list:*)",
      "Bash(gcloud compute backend-services describe:*)",
      "Bash(gcloud compute url-maps list:*)",
      "Bash(gcloud compute ssl-certificates list:*)",
      "Bash(gcloud compute instance-groups list:*)",
      "Bash(gcloud compute instance-groups describe:*)",
      "Bash(gcloud compute instance-groups managed list-instances:*)",
      "Bash(gcloud compute regions list:*)",
      "Bash(gcloud compute zones list:*)",

      // ── GKE ───────────────────────────────────────────────────────────────

      "Bash(gcloud container clusters list:*)",
      "Bash(gcloud container clusters describe:*)",
      "Bash(gcloud container node-pools list:*)",
      "Bash(gcloud container node-pools describe:*)",
      "Bash(gcloud container images list:*)",
      "Bash(gcloud container images describe:*)",
      "Bash(gcloud container images list-tags:*)",
      "Bash(gcloud container operations list:*)",
      "Bash(gcloud container operations describe:*)",

      // ── Cloud Run ─────────────────────────────────────────────────────────

      "Bash(gcloud run services list:*)",
      "Bash(gcloud run services describe:*)",
      "Bash(gcloud run revisions list:*)",
      "Bash(gcloud run revisions describe:*)",
      "Bash(gcloud run jobs list:*)",
      "Bash(gcloud run jobs describe:*)",

      // ── Cloud Functions ───────────────────────────────────────────────────

      "Bash(gcloud functions list:*)",
      "Bash(gcloud functions describe:*)",
      "Bash(gcloud functions get-iam-policy:*)",

      // ── Cloud Storage ─────────────────────────────────────────────────────

      "Bash(gcloud storage ls:*)",
      "Bash(gcloud storage buckets list:*)",
      "Bash(gcloud storage buckets describe:*)",
      "Bash(gcloud storage objects list:*)",

      // ── IAM ───────────────────────────────────────────────────────────────

      "Bash(gcloud iam roles list:*)",
      "Bash(gcloud iam roles describe:*)",
      "Bash(gcloud iam service-accounts list:*)",
      "Bash(gcloud iam service-accounts describe:*)",
      "Bash(gcloud iam service-accounts get-iam-policy:*)",
      "Bash(gcloud iam service-accounts keys list:*)",

      // ── Cloud SQL ─────────────────────────────────────────────────────────

      "Bash(gcloud sql instances list:*)",
      "Bash(gcloud sql instances describe:*)",
      "Bash(gcloud sql databases list:*)",
      "Bash(gcloud sql backups list:*)",
      "Bash(gcloud sql users list:*)",
      "Bash(gcloud sql ssl-certs list:*)",

      // ── Memorystore (Redis) ───────────────────────────────────────────────

      "Bash(gcloud redis instances list:*)",
      "Bash(gcloud redis instances describe:*)",

      // ── Pub/Sub ───────────────────────────────────────────────────────────

      "Bash(gcloud pubsub topics list:*)",
      "Bash(gcloud pubsub topics describe:*)",
      "Bash(gcloud pubsub subscriptions list:*)",
      "Bash(gcloud pubsub subscriptions describe:*)",

      // ── Secret Manager (list only — versions expose values) ───────────────

      "Bash(gcloud secrets list:*)",
      "Bash(gcloud secrets describe:*)",
      "Bash(gcloud secrets versions list:*)",

      // ── Artifact Registry ─────────────────────────────────────────────────

      "Bash(gcloud artifacts repositories list:*)",
      "Bash(gcloud artifacts repositories describe:*)",
      "Bash(gcloud artifacts packages list:*)",
      "Bash(gcloud artifacts versions list:*)",
      "Bash(gcloud artifacts tags list:*)",

      // ── Cloud DNS ─────────────────────────────────────────────────────────

      "Bash(gcloud dns managed-zones list:*)",
      "Bash(gcloud dns managed-zones describe:*)",
      "Bash(gcloud dns record-sets list:*)",

      // ── Cloud Logging ─────────────────────────────────────────────────────

      "Bash(gcloud logging logs list:*)",
      "Bash(gcloud logging sinks list:*)",
      "Bash(gcloud logging sinks describe:*)",
      "Bash(gcloud logging metrics list:*)",
      "Bash(gcloud logging read:*)",

      // ── Cloud Monitoring ──────────────────────────────────────────────────

      "Bash(gcloud monitoring dashboards list:*)",
      "Bash(gcloud monitoring dashboards describe:*)",
      "Bash(gcloud monitoring uptime list:*)",

      // ── Billing ───────────────────────────────────────────────────────────

      "Bash(gcloud billing accounts list:*)",
      "Bash(gcloud billing projects list:*)"
    ]
  }
}
