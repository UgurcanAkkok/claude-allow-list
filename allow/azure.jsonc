      "Bash(az mysql server list:*)",
      "Bash(az mysql server show:*)",
      "Bash(az redis list:*)",
      "Bash(az redis show:*)",

      // ── Monitor ───────────────────────────────────────────────────────────

      "Bash(az monitor metrics list:*)",
      "Bash(az monitor metrics list-definitions:*)",
      "Bash(az monitor log-analytics workspace list:*)",
      "Bash(az monitor log-analytics workspace show:*)",
      "Bash(az monitor alert list:*)",
      "Bash(az monitor action-group list:*)",
      "Bash(az monitor diagnostic-settings list:*)",
      "Bash(az monitor activity-log list:*)",

      // ── Service Bus ───────────────────────────────────────────────────────

      "Bash(az servicebus namespace list:*)",
      "Bash(az servicebus namespace show:*)",
      "Bash(az servicebus topic list:*)",
      "Bash(az servicebus queue list:*)",

      // ── Resource & tags ───────────────────────────────────────────────────

      "Bash(az resource list:*)",
      "Bash(az resource show:*)",
      "Bash(az tag list:*)",
      "Bash(az provider list:*)",
      "Bash(az provider show:*)",
      "Bash(az location list:*)"
    ]
  }
